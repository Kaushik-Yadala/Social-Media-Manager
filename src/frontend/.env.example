# Frontend API base URL (FastAPI backend)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional dedicated ML service base URL for Predictive Insights.
# Defaults to http://localhost:8001 in code when not set.
NEXT_PUBLIC_ML_API_BASE_URL=http://localhost:8001

