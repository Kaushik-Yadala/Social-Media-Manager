# Frontend API base URL (FastAPI backend)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional dedicated ML service base URL for Predictive Insights.
# If omitted, frontend falls back to NEXT_PUBLIC_API_BASE_URL.
# Example when ML service runs separately: http://localhost:8001
NEXT_PUBLIC_ML_API_BASE_URL=http://localhost:8000

# Backward-compatible alias still supported by code
# NEXT_PUBLIC_API_URL=http://localhost:8000
